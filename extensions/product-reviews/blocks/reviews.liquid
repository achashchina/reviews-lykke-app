<div class="reviews-block">
  <div class="reviews-header">
    <h4 style="margin-bottom: 12px;">Product Reviews</h4>
    <button id="open-review-modal">Write a review</button>
  </div>

  <div id="reviews-summary-section" style="padding: 30px; text-align: center; background-color:#f7f6f2;"></div>

  <div id="review-modal" class="review-modal">
    <div class="review-modal-content">
      <button class="review-modal-close" id="close-review-modal" style="color: black;">✕</button>

      <h5>Share Your Thoughts with Others</h5>

      <form method="post" action="/apps/reviews">
        <input type="hidden" name="productId" value="{{ product.id }}">
        <input type="hidden" name="returnTo" value="{{ shop.url }}{{ product.url }}">

        <div style="margin-bottom: 12px;">
          <label for="review-name">Username</label><br>
          <input id="review-name" type="text" name="name" required>
        </div>

        <div style="margin-bottom: 12px;">
          <label for="review-rating">Rating</label><br>
          <div class="rating-input" id="rating-input">
            <input type="hidden" name="rating" id="rating-value" value="0">

            <div class="rating-stars">
              <svg data-value="1" viewBox="0 0 20 20">
                <path d="M10 1.5l2.6 5.4 6 .9-4.3 4.2 1 6-5.3-2.8-5.3 2.8 1-6L1.4 7.8l6-.9L10 1.5z"/>
              </svg>
              <svg data-value="2" viewBox="0 0 20 20">
                <path d="M10 1.5l2.6 5.4 6 .9-4.3 4.2 1 6-5.3-2.8-5.3 2.8 1-6L1.4 7.8l6-.9L10 1.5z"/>
              </svg>
              <svg data-value="3" viewBox="0 0 20 20">
                <path d="M10 1.5l2.6 5.4 6 .9-4.3 4.2 1 6-5.3-2.8-5.3 2.8 1-6L1.4 7.8l6-.9L10 1.5z"/>
              </svg>
              <svg data-value="4" viewBox="0 0 20 20">
                <path d="M10 1.5l2.6 5.4 6 .9-4.3 4.2 1 6-5.3-2.8-5.3 2.8 1-6L1.4 7.8l6-.9L10 1.5z"/>
              </svg>
              <svg data-value="5" viewBox="0 0 20 20">
                <path d="M10 1.5l2.6 5.4 6 .9-4.3 4.2 1 6-5.3-2.8-5.3 2.8 1-6L1.4 7.8l6-.9L10 1.5z"/>
              </svg>
            </div>
          </div>
        </div>

        <div style="margin-bottom: 12px;">
          <label for="review-text">Review</label><br>
          <textarea id="review-text" name="text" required style="width: 100%;"></textarea>
        </div>

        <button type="submit">Submit review</button>
      </form>
    </div>
  </div>

  <div id="reviews-list">Loading reviews...</div>
  <div id="reviews-actions" style="margin-top: 16px;"></div>

  <hr style="margin: 24px 0;">
</div>

<script>
  function renderStars(avg) {
    const full = Math.floor(avg);
    const half = avg % 1 >= 0.5 ? 1 : 0;
    const empty = 5 - full - half;

    const star = (className) => `
    <svg viewBox="0 0 20 20" class="${className}">
        <path d="M10 1.5l2.6 5.4 6 .9-4.3 4.2 1 6-5.3-2.8-5.3 2.8 1-6L1.4 7.8l6-.9L10 1.5z"/>
    </svg>
    `;

    return `
        ${star('star-full').repeat(full)}
        ${half ? star('star-half') : ''}
        ${star('star-empty').repeat(empty)}
    `;
  }
  (async function () {
    const productId = '{{ product.id }}';
    const list = document.getElementById('reviews-list');
    const summary = document.getElementById('reviews-summary-section');
    const actions = document.getElementById('reviews-actions');

    try {
      const url = `${window.location.origin}/apps/reviews?productId=${encodeURIComponent(productId)}`;

      const response = await fetch(url, {
        headers: {
          'ngrok-skip-browser-warning': 'true',
        },
      });

      const raw = await response.text();

      let data;
      try {
        data = JSON.parse(raw);
      } catch (e) {
        list.innerHTML = '<p>Failed to load reviews.</p>';
        return;
      }

      if (!response.ok || !data.ok) {
        list.innerHTML = '<p>Failed to load reviews.</p>';
        return;
      }

      if (!data.reviews || data.reviews.length === 0) {
        list.innerHTML = '<p>No reviews yet.</p>';
        return;
      }

      const reviews = data.reviews;

      let avg = 0;

      if (reviews.length > 0) {
        avg = reviews.reduce((sum, r) => sum + r.rating, 0) / reviews.length;
      }

      summary.innerHTML = `
        <div style="display:flex;align-items:center;flex-direction: column;gap:10px;">
        <div>
             <span style="font-size:14px;">
                ${avg.toFixed(1)} out of 5
            </span>
            <span style="font-size:14px;color:#666;">
                (${reviews.length} reviews)
            </span>
        </div>

        <div class="review-stars">
            ${renderStars(avg)}
        </div>
        </div>
    `;

      const firstFive = reviews.slice(0, 5);

      list.innerHTML = firstFive
        .map(
          (review) => `
        <div class="review-item">
            <div
            style="
                display:flex;
                flex-direction:column;
                gap:8px;
                min-width:0;
            "
            >
            <strong style="line-height:1.4;">${review.name}</strong>
            <div class="review-stars">
                ${renderStars(review.rating)}
            </div>
            </div>

            <div style="min-width:0;">
            <p style="margin:0; line-height:1.6;">
                ${review.text}
            </p>
            </div>
        </div>
        `
        )
        .join('');

      if (reviews.length > 5) {
        actions.innerHTML = `
          <button type="button" id="view-all-reviews-btn">
            View all reviews
          </button>
        `;

        document.getElementById('view-all-reviews-btn').addEventListener('click', function () {
          list.innerHTML = reviews
            .map(
              (review) => `
            <div style="margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid #ddd;">
              <strong>${review.name}</strong><br>
              <span>${'★'.repeat(review.rating)}${'☆'.repeat(5 - review.rating)}</span>
              <p>${review.text}</p>
            </div>
          `
            )
            .join('');

          actions.innerHTML = '';
        });
      }
    } catch (error) {
      list.innerHTML = '<p>Failed to load reviews.</p>';
    }
  })();
</script>

<script>
    const modal = document.getElementById('review-modal');
    const openBtn = document.getElementById('open-review-modal');
    const closeBtn = document.getElementById('close-review-modal');

    const isLoggedIn = {% if customer %}true{% else %}false{% endif %};
    const loginUrl = "{{ routes.storefront_login_url }}";


    console.log('isLoggedIn**************',isLoggedIn)
    console.log('loginUrl**************',loginUrl)

    openBtn.addEventListener("click", () => {

      if (!isLoggedIn) {
        window.location.href = loginUrl;
        return;
      }

      modal.classList.add("active");
    });

    closeBtn.addEventListener('click', () => {
      modal.classList.remove('active');
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.remove('active');
      }
    });
</script>

<script>
  const stars = document.querySelectorAll('#rating-input svg');
  const ratingInput = document.getElementById('rating-value');

  let selectedRating = 0;

  stars.forEach((star) => {
    star.addEventListener('mouseover', () => {
      const value = star.dataset.value;

      stars.forEach((s) => {
        s.classList.toggle('hover', s.dataset.value <= value);
      });
    });

    star.addEventListener('mouseout', () => {
      stars.forEach((s) => s.classList.remove('hover'));
    });

    star.addEventListener('click', () => {
      selectedRating = star.dataset.value;
      ratingInput.value = selectedRating;

      stars.forEach((s) => {
        s.classList.toggle('active', s.dataset.value <= selectedRating);
      });
    });
  });
</script>

<style>
  input,
  textarea {
    border: 1px solid #ccc;
  }

  *:focus-visible {
    outline: none;
    outline-offset: 0;
  }

  button {
    padding-inline: 24px;
    padding-block: 16px;
    background: black;
    color: white;
    border: none;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    cursor: pointer;
  }
  .rating-stars {
    display: flex;
    gap: 4px;
    cursor: pointer;
  }

  .reviews-header {
    display: flex;
    justify-content: space-between;
  }

  #open-review-modal {
    letter-spacing: inherit;
    text-align: left;
    background: none;
    text-decoration: underline;
    color: #167a92;
    text-transform: none;
  }

  .rating-stars svg {
    width: 22px;
    height: 22px;
    fill: #ddd;
    transition: fill 0.2s;
  }

  .rating-stars svg.active {
    fill: #ff9800;
  }

  .rating-stars svg.hover {
    fill: #ff9800;
  }
  .review-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 999;
  }

  .review-modal.active {
    display: flex;
  }

  .review-modal-content {
    background: white;
    padding: 28px;
    width: 100%;
    max-width: 480px;
    border-radius: 8px;
    position: relative;
  }

  .review-modal-close {
    position: absolute;
    right: 14px;
    top: 14px;
    border: none;
    background: none;
    font-size: 18px;
    cursor: pointer;
  }

  .review-field {
    margin-bottom: 14px;
  }

  .review-field input,
  .review-field textarea,
  .review-field select {
    width: 100%;
    padding: 8px;
  }
  .review-stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
  }

  .review-stars svg {
    width: 18px;
    height: 18px;
  }

  .review-stars .star-empty {
    fill: #ddd;
  }

  .review-stars .star-full {
    fill: #ff9800;
  }

  .review-stars .star-half {
    fill: url(#half-gradient);
  }

  .review-item {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 24px;
    padding: 16px 0;
    align-items: start;
  }
  @media (max-width: 749px) {
    .review-item {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }

  h5 {
    margin-top: 0;
  }
</style>

{% schema %}
{
  "name": "Reviews",
  "target": "section",
  "settings": []
}
{% endschema %}
